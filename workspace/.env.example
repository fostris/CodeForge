import os

def create_env_example():
    env_vars = [
        ('DATABASE_URL', 'your_database_url_here', '# Database URL'),
        ('SECRET_KEY', 'your_secret_key_here', '# Secret key for JWT encoding/decoding'),
        ('DEBUG', 'False', '# Enable or disable debug mode'),
        ('API_V1_STR', '/api/v1', '# API v1 string path prefix'),
        ('PROJECT_NAME', 'my_project', '# Project name')
    ]
    
    if os.path.exists('.env.example'):
        return
    
    with open('.env.example', 'w') as file:
        for key, value, comment in env_vars:
            file.write(f'{key}={value}\n')
            file.write(f'{comment}\n')